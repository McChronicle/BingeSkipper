{
    "manifest_version": 3,
    "name": "Netflix AutoSkip",
    "description": "Autoclicker for Netflix intros, recaps, credits and continue watching prompts",
    "version": "0.3.1",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": ["https://www.netflix.com/*"],
            "js": ["netflix/content/content.js"],
            "run_at": "document_end"
        },
        {
            "matches": ["https://www.amazon.*/gp/video/*"],
            "js": ["amazon/content/content.js"],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "service_worker.js"
    },
    "action": {
        "default_popup": "default/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "permissions": [
        "storage",
        "tabs"
    ]
}